generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid())
  nickname       String
  email          String
  provider       String         @default("google")
  providerId     String         @map("provider_id")
  profileImage   String         @map("profile_image")
  
  isTermsAgreed  Boolean        @default(false) @map("is_terms_agreed")
  
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  ruleTemplates RuleTemplate[]
  rooms         Room[]
  roomMembers   RoomMember[]

  @@unique([provider, providerId])
  @@map("USER")
}

model RuleTemplate {
  id         String        @id @default(uuid())
  userId     String?       @map("user_id")
  title      String?      
  isSaved    Boolean       @default(false) @map("is_saved")
  focusMin   Int           @map("focus_min")
  breakMin   Int           @map("break_min")
  rounds     Int
  tierConfig Json          @map("tier_config")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  user       User?         @relation(fields: [userId], references: [id])
  penalties  PenaltyItem[]
  rooms      Room[]

  @@unique([userId, title])
  @@map("RULE_TEMPLATE")
}

model PenaltyItem {
  id         String       @id @default(uuid())
  templateId String       @map("template_id")
  content    String

  template   RuleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("PENALTY_ITEM")
}

model Room {
  code         String        @id
  title        String
  hostId       String        @map("host_id")
  templateId   String?       @map("template_id")
  passwordHash String        @map("password_hash")
  phase        String
  status       String?
  startedAt    DateTime?     @map("started_at")
  endedAt      DateTime?     @map("ended_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  closedAt     DateTime?     @map("closed_at")

  host         User          @relation(fields: [hostId], references: [id])
  template     RuleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  roomMembers  RoomMember[]
  roomResults  RoomResult[]

  @@map("ROOM")
}

model RoomMember {
  id           String       @id @default(uuid())
  roomCode     String       @map("room_code")
  userId       String?      @map("user_id")
  guestToken   String?      @map("guest_token")
  nickname     String
  profileImage String?      @map("profile_image")
  isHost       Boolean      @default(false) @map("is_host")
  isLoggedIn   Boolean      @map("is_logged_in")
  joinedAt     DateTime     @default(now()) @map("joined_at")
  gaveUpAt     DateTime?    @map("gave_up_at")

  room         Room         @relation(fields: [roomCode], references: [code], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
  escapeLogs   EscapeLog[]
  result       RoomResult?

  @@unique([roomCode, userId])
  @@map("ROOM_MEMBER")
}

model EscapeLog {
  id           String     @id @default(uuid())
  roomMemberId String     @map("room_member_id")
  escapedAt    DateTime   @map("escaped_at")
  returnedAt   DateTime?  @map("returned_at")
  durationMs   Int?       @map("duration_ms")
  deletedAt    DateTime?  @map("deleted_at")

  roomMember   RoomMember @relation(fields: [roomMemberId], references: [id], onDelete: Restrict)

  @@map("ESCAPE_LOG")
}

model RoomResult {
  roomMemberId  String          @id @map("room_member_id")
  roomCode      String          @map("room_code")
  totalEscapeMs Int             @map("total_escape_ms")
  penaltyTier   Int             @map("penalty_tier")
  createdAt     DateTime        @default(now()) @map("created_at")

  roomMember    RoomMember      @relation(fields: [roomMemberId], references: [id], onDelete: Cascade)
  room          Room            @relation(fields: [roomCode], references: [code], onDelete: Cascade)
  penalties     ResultPenalty[]

  @@map("ROOM_RESULT")
}

model ResultPenalty {
  roomMemberId String     @map("room_member_id")
  content      String
  count        Int        @default(1)
  isRevealed   Boolean    @default(false) @map("is_revealed")

  roomResult   RoomResult @relation(fields: [roomMemberId], references: [roomMemberId], onDelete: Cascade)

  @@id([roomMemberId, content])
  @@map("RESULT_PENALTY")
}